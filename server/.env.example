# Backend Environment Variables
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (SQL Server)
# Format: sqlserver://username:password@host:port/database
# For IP addresses, encryption is automatically disabled
DATABASE_URL=sqlserver://username:password@your-db-host:1433/database_name

# Alternative Database Configuration (if you prefer individual variables)
# DB_SERVER=your-db-host
# DB_PORT=1433
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_NAME=your_database_name

# JWT Configuration (REQUIRED - server will not start without this)
# Generate a strong secret (minimum 64 characters): openssl rand -base64 64
# WARNING: Using a weak secret makes your app vulnerable to token forgery attacks
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_64_minimum_64_chars
JWT_EXPIRES_IN=1h

# CORS Configuration
# In PRODUCTION: Only list your actual production domain(s)
# In development: localhost origins are allowed by default
# Comma-separated for multiple origins: https://example.com,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# Optional: Email Configuration (for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
# SMTP_FROM=noreply@alumni-connect.com

# Push Notifications Configuration (for Web Push notifications)
# Generate VAPID keys using: npx web-push generate-vapid-keys
# These keys are required for push notifications to work
# VAPID_PUBLIC_KEY=your_vapid_public_key_here
# VAPID_PRIVATE_KEY=your_vapid_private_key_here
# VAPID_EMAIL=mailto:admin@alumni-connect.com
